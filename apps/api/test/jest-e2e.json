{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testMatch": ["**/test/e2e/**/*.e2e-spec.ts"],
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "collectCoverageFrom": ["src/**/*.ts", "!src/**/*.spec.ts"],
  "coverageDirectory": "./coverage/integration",
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/src/$1"
  },
  "testTimeout": 30000,

  "coverageProvider": "v8",
  "coverageThreshold": {
    "global": {
      "lines": 80,
      "statements": 80,
      "functions": 80,
      "branches": 80
    }
  }
}

