{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "src",
  "testEnvironment": "node",
  "testMatch": ["<rootDir>/../test/e2e/**/*.e2e-spec.ts"],
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "collectCoverageFrom": ["**/*.ts", "!**/*.spec.ts"],
  "coverageDirectory": "../coverage/integration",
  "testTimeout": 30000
}
